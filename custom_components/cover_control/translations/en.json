  "services": {
    "set_manual_override": {
      "name": "Set manual override",
      "description": "Pause automatic control for a cover for the given minutes.",
      "target": {
        "entity": {
          "name": "Cover",
          "description": "Cover to pause automation for."
        }
      },
      "fields": {
        "manual_override_minutes": {
          "name": "Minutes",
          "description": "Duration of the pause."
        }
      }
    },
    "clear_manual_override": {
      "name": "Clear manual override",
      "description": "Resume automation immediately for the selected cover.",
      "target": {
        "entity": {
          "name": "Cover",
          "description": "Cover to resume automation for."
        }
      },
      "fields": {}
    },
    "activate_shading": {
      "name": "Activate shading now",
      "description": "Send a cover to the shading position immediately and hold it there for the override duration.",
      "target": {
        "entity": {
          "name": "Cover",
          "description": "Cover that should move to the shading position."
        }
      },
      "fields": {
        "manual_override_minutes": {
          "name": "Minutes",
          "description": "Optional override duration; defaults to the integration setting."
        }
      }
    },
    "recalibrate_cover": {
      "name": "Recalibrate cover",
      "description": "Temporarily override a cover, use the standard open command to fully open it, then return to the previous position and clear the override. Use this when a cover needs to be realigned.",
      "target": {
        "entity": {
          "name": "Cover",
          "description": "Cover to recalibrate."
        }
      },
      "fields": {
        "full_open_position": {
          "name": "Fully open position",
          "description": "Position to use for fully opening the cover; defaults to 100%."
        }
      }
    },
    "change_switch_settings": {
      "name": "Update switch settings",
      "description": "Apply configuration values for an automation toggle switch.",
      "fields": {
        "entity_id": {
          "name": "Automation switch",
          "description": "Switch entity that represents the automation to update."
        },
        "settings": {
          "name": "Settings",
          "description": "Key/value pairs to store with the switch's configuration category."
        }
      }
     },
    "force_action": {
      "name": "Force action",
      "description": "Run an immediate action on the selected cover without further automation checks.",
      "target": {
        "entity": {
          "name": "Cover",
          "description": "Cover to run the action on."
        }
      },
      "fields": {
        "action": {
          "name": "Action",
          "description": "Select which immediate action to run."
        }
      }
    }
